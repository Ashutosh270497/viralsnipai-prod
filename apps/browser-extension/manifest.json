{
  "manifest_version": 3,
  "name": "SnipRadar for X",
  "version": "0.1.0",
  "description": "Save tweets, threads, and profiles from X into SnipRadar Research Inbox.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "notifications",
    "alarms",
    "windows"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Open SnipRadar"
    },
    "save-focused-tweet": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Save focused tweet to SnipRadar inbox"
    }
  },
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://viralsnipai.com/*",
    "https://*.viralsnipai.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://localhost:3200/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "SnipRadar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "content-script.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
