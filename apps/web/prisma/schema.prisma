generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  emailVerified DateTime?
  name         String?
  image        String?
  plan         String      @default("free")
  referralCode String?     @unique
  referredBy   String?
  referralCreditGrantedAt DateTime?

  // YouTube Creator Fields
  youtubeChannelUrl String?
  subscriberCount   Int?      @default(0)
  selectedNiche     String?
  nicheData         Json?
  onboardingCompleted Boolean @default(false)
  subscriptionTier  String    @default("free") // 'free', 'starter', 'creator', 'studio'
  subscriptionStatus String   @default("active")
  stripeCustomerId  String?   // Legacy placeholder from pre-Razorpay billing model
  billingProvider   String    @default("razorpay")
  razorpayCustomerId String?
  razorpaySubscriptionId String?
  billingCycle      String    @default("monthly")
  subscriptionCurrentStart DateTime?
  subscriptionCurrentEnd DateTime?
  subscriptionCancelAtPeriodEnd Boolean @default(false)
  creditsRemaining  Int       @default(5)

  // Authentication & Onboarding Fields
  password          String?    // Optional for OAuth users
  goalSelection     String?    // Legacy YouTube goal — 'start_channel', 'grow_channel', 'monetization', 'professional'
  nicheInterests    String[]   @default([]) // Array of selected niches
  resetToken        String?
  resetTokenExpiry  DateTime?

  // V1 Onboarding Fields
  creatorType       String?    // 'founder', 'coach', 'agency', 'youtuber', 'podcaster', 'marketer', 'other'
  primaryPlatform   String?    // 'youtube_shorts', 'instagram_reels', 'tiktok', 'linkedin', 'x'
  contentGoal       String?    // 'more_reach', 'more_leads', 'faster_editing', 'repurpose_long_form', 'personal_brand'

  projects     Project[]
  brandKit     BrandKit?
  accounts     Account[]
  sessions     Session[]
  transcriptJobs TranscriptJob[]
  voiceProfiles VoiceProfile[]
  voiceRenders VoiceRender[]

  // YouTube Creator Relations
  contentIdeas    ContentIdea[]
  contentCalendars ContentCalendar[]
  generatedScripts GeneratedScript[]
  generatedTitles GeneratedTitle[]
  thumbnails      Thumbnail[]
  usageLogs       UsageLog[]
  scriptVersions  ScriptVersion[]
  scriptShares    ScriptShare[]    @relation(name: "ScriptSharedBy")
  scriptComments  ScriptComment[]
  scriptAudios    ScriptAudio[]
  subscription    Subscription?
  usageTracking   UsageTracking[]

  // Keyword Research Relations
  keywordResearches KeywordResearch[]
  savedKeywords     SavedKeyword[]

  // Competitor Tracking Relations
  competitors       Competitor[]
  competitorAlerts  CompetitorAlert[]

  // SnipRadar Relations
  xAccounts         XAccount[]
  xTrackedAccounts  XTrackedAccount[]
  tweetDrafts       TweetDraft[]
  xSchedulerRuns    XSchedulerRun[]
  xEngagementOpportunities XEngagementOpportunity[]
  xAutoDmAutomations XAutoDmAutomation[]
  xAutoDmDeliveries XAutoDmDelivery[]
  xStyleProfile     XStyleProfile?
  xProfileAuditSnapshots XProfileAuditSnapshot[]
  xResearchDocuments XResearchDocument[]
  xResearchIndexRuns XResearchIndexRun[]
  xResearchInboxItems XResearchInboxItem[]
  xRelationshipLeads XRelationshipLead[]
  xRelationshipInteractions XRelationshipInteraction[]
  snipRadarApiKeys SnipRadarApiKey[]
  snipRadarWebhookSubscriptions SnipRadarWebhookSubscription[]
  snipRadarWebhookEvents SnipRadarWebhookEvent[]
  snipRadarChatSessions SnipRadarChatSession[]
  razorpayWebhookEvents RazorpayWebhookEvent[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  title        String
  topic        String?
  sourceUrl    String?
  // V1 project context fields
  targetPlatform String?  // 'youtube_shorts', 'instagram_reels', 'tiktok', 'linkedin', 'x'
  contentGoal    String?  // 'more_reach', 'more_leads', 'faster_editing', 'repurpose_long_form', 'personal_brand'
  script       Script?   @relation("ProjectScript")
  assets       Asset[]
  clips        Clip[]
  exports      Export[]
  youtubeIngestJobs YouTubeIngestJob[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([userId, updatedAt])
}

model Script {
  id        String   @id @default(cuid())
  hooks     Json
  body      String   @db.Text
  tone      String?
  project   Project? @relation("ProjectScript", fields: [projectId], references: [id])
  projectId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id                String                  @id @default(cuid())
  projectId         String
  project           Project                 @relation(fields: [projectId], references: [id])
  type              String
  path              String
  storagePath       String
  durationSec       Int?
  transcript        String?                 @db.Text
  sourceLanguage    String                  @default("en")
  clips             Clip[]                  @relation("AssetClips")
  translations      TranscriptTranslation[]
  voiceTranslations VoiceTranslation[]
  youtubeIngestJobs YouTubeIngestJob[]
  createdAt         DateTime                @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
}

model Clip {
  id                  String               @id @default(cuid())
  projectId           String
  project             Project              @relation(fields: [projectId], references: [id])
  assetId             String?
  asset               Asset?               @relation("AssetClips", fields: [assetId], references: [id])
  startMs             Int
  endMs               Int
  title               String?
  summary             String?              @db.Text
  callToAction        String?
  captionSrt          String?              @db.Text
  captionStyle        Json?
  previewPath         String?
  thumbnail           String?
  viralityScore       Int?
  viralityFactors     Json?
  order               Int                  @default(0)
  captionTranslations CaptionTranslation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([projectId])
  @@index([assetId])
  @@index([projectId, assetId])
  @@index([projectId, viralityScore(sort: Desc)])
  @@index([projectId, order])
}

model Export {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  clipIds    Json
  preset     String
  includeCaptions Boolean @default(false)
  outputPath String
  storagePath String
  status     String   @default("queued")
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([projectId, status])
}

model BrandKit {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id])
  primaryHex   String  @default("#00A3FF")
  fontFamily   String  @default("Inter")
  logoPath     String?
  logoStoragePath String?
  captionStyle Json
  watermark    Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TranscriptJob {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  status      String   @default("processing")
  sourceType  String
  sourceUrl   String?
  filePath    String?
  fileUrl     String?
  title       String?
  durationSec Int?
  transcript  String?  @db.Text
  segments    Json?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model VoiceProfile {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  name              String
  description       String?
  providerVoiceId   String         @unique
  samplePath        String?
  sampleStoragePath String?
  metadata          Json?
  renders           VoiceRender[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
}

model VoiceRender {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  voiceId          String
  voice            VoiceProfile @relation(fields: [voiceId], references: [id])
  text             String       @db.Text
  audioPath        String
  audioStoragePath String
  durationSec      Int?
  createdAt        DateTime     @default(now())

  @@index([userId])
  @@index([voiceId])
  @@index([userId, voiceId])
}

model RazorpayWebhookEvent {
  id                     String   @id @default(cuid())
  providerEventId        String   @unique
  eventType              String
  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  razorpaySubscriptionId String?
  payload                Json
  processedAt            DateTime?
  createdAt              DateTime @default(now())

  @@index([userId, createdAt])
  @@index([razorpaySubscriptionId, createdAt])
  @@map("razorpay_webhook_events")
}

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                 String   @default("free")
  status                 String   @default("active")
  billingRegion          String   @default("IN")
  razorpaySubscriptionId String?  @unique
  razorpayCustomerId     String?
  stripeSubscriptionId   String?  @unique
  stripeCustomerId       String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean  @default(false)
  promoCode              String?
  freeMonthsCredit       Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([planId, status])
  @@index([billingRegion, status])
  @@map("subscriptions")
}

model UsageTracking {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month           String
  viralFetches    Int      @default(0)
  hookGenerations Int      @default(0)
  scheduledPosts  Int      @default(0)
  engagementOpps  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, month])
  @@index([month])
  @@map("usage_tracking")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Multi-Language Support Models

model TranscriptTranslation {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  language       String
  transcript     String   @db.Text
  segments       Json?
  translatedFrom String
  translatedAt   DateTime @default(now())

  @@unique([assetId, language])
  @@index([assetId])
  @@index([language])
  @@map("transcript_translations")
}

model CaptionTranslation {
  id         String   @id @default(cuid())
  clipId     String
  clip       Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  language   String
  captionSrt String   @db.Text
  createdAt  DateTime @default(now())

  @@unique([clipId, language])
  @@index([clipId])
  @@index([language])
  @@map("caption_translations")
}

model VoiceTranslation {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  language       String
  audioUrl       String
  voiceId        String?
  status         String   @default("queued")
  translatedFrom String
  processingTime Int?
  error          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([assetId, language])
  @@index([assetId])
  @@index([status])
  @@index([language])
  @@map("voice_translations")
}

model YouTubeIngestJob {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceUrl      String
  assetId        String?
  asset          Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  status         String   @default("queued")
  processingTime Int?
  metadata       Json?
  error          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([assetId])
  @@map("youtube_ingest_jobs")
}

// ============================================
// YouTube Creator Platform Models
// ============================================

model Niche {
  id                    String   @id @default(cuid())
  name                  String
  category              String   // 'technology', 'lifestyle', 'education', etc.
  description           String?  @db.Text
  competitionLevel      String   // 'low', 'medium', 'high'
  monetizationPotential Int      // 1-10 scale
  averageCpm            Decimal? @db.Decimal(10, 2)
  averageViewsPerVideo  Int?
  growthTrend           String   // 'rising', 'stable', 'declining'
  exampleChannels       Json?    // [{name, url, subscribers}]
  keywords              Json?    // [keyword1, keyword2, ...]
  targetAudience        String?  @db.Text
  contentTypes          Json?    // ['tutorial', 'review', 'vlog']
  createdAt             DateTime @default(now())

  @@map("niches")
}

model ContentIdea {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarId      String?
  calendar        ContentCalendar? @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  title           String
  description     String?  @db.Text
  niche           String?
  videoType       String?  // 'short', 'long-form', 'live'
  viralityScore   Int?     // 1-100
  keywords        Json?    // ['keyword1', 'keyword2']
  searchVolume    Int?
  competitionScore Int?
  estimatedViews  Int?
  scheduledDate   DateTime?
  status          String   @default("idea") // 'idea', 'scripted', 'published'
  aiReasoning     String?  @db.Text // Why this idea is good
  contentCategory String?  // 'trending', 'evergreen', 'experimental'
  hookSuggestions Json?    // Array of hook ideas
  thumbnailIdeas  Json?    // Array of thumbnail concepts

  generatedScripts GeneratedScript[]
  generatedTitles GeneratedTitle[]
  thumbnails      Thumbnail[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([calendarId])
  @@index([scheduledDate])
  @@index([userId, scheduledDate])
  @@map("content_ideas")
}

model ContentCalendar {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche           String
  startDate       DateTime
  endDate         DateTime
  durationDays    Int      // 7, 14, or 30
  generationStatus String  @default("pending") // 'pending', 'generating', 'completed', 'failed'
  metadata        Json?    // Additional generation params

  ideas           ContentIdea[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@map("content_calendars")
}

model GeneratedScript {
  id               String                @id @default(cuid())
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentIdeaId    String?
  contentIdea      ContentIdea?          @relation(fields: [contentIdeaId], references: [id], onDelete: Cascade)
  title            String
  hook             String?               @db.Text
  intro            String?               @db.Text
  mainContent      String?               @db.Text
  conclusion       String?               @db.Text
  cta              String?               @db.Text
  fullScript       String?               @db.Text
  durationEstimate Int?                  // in seconds
  retentionTips    Json?
  keywords         Json?                 // SEO keywords
  scriptStyle      String?
  tone             String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  versions         ScriptVersion[]
  shares           ScriptShare[]
  comments         ScriptComment[]
  audioFiles       ScriptAudio[]

  @@index([userId])
  @@index([contentIdeaId])
  @@index([userId, contentIdeaId])
  @@map("generated_scripts")
}

model ScriptVersion {
  id               String          @id @default(cuid())
  scriptId         String
  script           GeneratedScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versionNumber    Int
  title            String
  hook             String?         @db.Text
  intro            String?         @db.Text
  mainContent      String?         @db.Text
  conclusion       String?         @db.Text
  cta              String?         @db.Text
  fullScript       String?         @db.Text
  durationEstimate Int?
  changeDescription String?        @db.Text
  createdAt        DateTime        @default(now())

  @@index([scriptId])
  @@index([userId])
  @@map("script_versions")
}

model ScriptShare {
  id               String          @id @default(cuid())
  scriptId         String
  script           GeneratedScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  sharedBy         String
  sharedByUser     User            @relation(name: "ScriptSharedBy", fields: [sharedBy], references: [id], onDelete: Cascade)
  sharedWith       String?         // Email or user ID
  shareToken       String          @unique
  accessLevel      String          @default("view") // 'view' or 'edit'
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())

  @@index([scriptId])
  @@index([sharedBy])
  @@index([shareToken])
  @@map("script_shares")
}

model ScriptComment {
  id               String          @id @default(cuid())
  scriptId         String
  script           GeneratedScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  section          String?         // 'hook', 'intro', 'main', 'conclusion', 'cta'
  content          String          @db.Text
  resolved         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([scriptId])
  @@index([userId])
  @@map("script_comments")
}

model GeneratedTitle {
  id                      String       @id @default(cuid())
  userId                  String
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentIdeaId           String?
  contentIdea             ContentIdea? @relation(fields: [contentIdeaId], references: [id], onDelete: Cascade)
  generationBatchId       String       // Groups titles from same generation

  // Title content
  title                   String       @db.Text
  videoTopic              String
  keywords                Json         // Array of target keywords
  targetAudience          String
  titleStyle              String       // 'how-to', 'listicle', 'curiosity', 'question', 'authority', 'mixed'
  maxLength               Int          @default(70)
  characterLength         Int

  // Scoring (all 1-100 scale for consistency)
  ctrScore                Int?         // Overall predicted CTR
  keywordOptimizationScore Int?        // How well keywords are placed
  curiosityScore          Int?         // Curiosity factor
  clarityScore            Int?         // Clarity and understandability
  powerWordCount          Int?         // Number of power words used
  overallRank             Int?         // 1-10 ranking within batch

  // Analysis
  reasoning               String?      @db.Text  // Why this title will work
  keywordOptimized        Boolean      @default(false)
  lengthOptimal           Boolean      @default(false)
  titleType               String?      // More specific: 'curiosity', 'how-to', 'listicle', etc.

  // Selection
  isFavorite              Boolean      @default(false)
  isPrimary               Boolean      @default(false)  // Selected as main title

  createdAt               DateTime     @default(now())

  @@index([userId])
  @@index([contentIdeaId])
  @@index([generationBatchId])
  @@index([userId, contentIdeaId])
  @@index([userId, createdAt])
  @@map("generated_titles")
}

model Thumbnail {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentIdeaId    String?
  contentIdea      ContentIdea? @relation(fields: [contentIdeaId], references: [id], onDelete: Cascade)
  generationBatchId String      // Groups thumbnails from same generation

  // Source info
  videoTitle       String
  niche            String?

  // Generation settings
  thumbnailStyle   String       // 'bold', 'minimal', 'dramatic', 'informative', 'meme'
  mainSubject      String       // 'person', 'product', 'text', 'abstract'
  colorScheme      String       // 'vibrant', 'dark', 'bright', 'professional', 'auto'
  includeText      Boolean      @default(false)
  textOverlay      String?      // Max 3-5 words
  faceExpression   String?      // 'excited', 'shocked', 'serious', 'happy'
  additionalElements Json?      // Array of elements: ["arrows", "circles", "emojis"]

  // Generated assets
  imageUrl         String       // Public URL from Supabase Storage
  storagePath      String       // Internal storage path
  thumbnailPrompt  String       @db.Text // DALL-E prompt used
  aiModel          String       @default("dall-e-3") // 'dall-e-3', 'sdxl'

  // AI Analysis scores (1-100 scale)
  ctrScore         Int?         // Predicted CTR
  contrastScore    Int?         // How well it stands out
  mobileReadability Int?        // Can you see it on phone
  emotionalImpact  Int?         // Does it evoke emotion
  nicheAlignment   Int?         // Fits niche expectations
  overallRank      Int?         // 1-5 ranking within batch

  // Analysis feedback
  improvements     Json?        // Array of improvement suggestions
  reasoning        String?      @db.Text // Why this thumbnail will work

  // User actions
  isPrimary        Boolean      @default(false) // Selected as main thumbnail
  isFavorite       Boolean      @default(false)

  createdAt        DateTime     @default(now())

  @@index([userId])
  @@index([contentIdeaId])
  @@index([generationBatchId])
  @@index([userId, contentIdeaId])
  @@index([userId, createdAt])
  @@map("thumbnails")
}

model ScriptAudio {
  id               String          @id @default(cuid())
  scriptId         String
  script           GeneratedScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceId          String
  voiceModel       String
  audioUrl         String
  audioStoragePath String
  durationSec      Int
  format           String          @default("mp3")
  fileSize         Int
  section          String?
  language         String?
  sourceLanguage   String?
  isTranslated     Boolean         @default(false)
  createdAt        DateTime        @default(now())

  @@index([scriptId])
  @@index([userId])
  @@index([scriptId, createdAt])
  @@index([userId, createdAt])
  @@index([language])
  @@map("script_audios")
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature      String   // 'niche_discovery', 'content_idea', 'script', 'title', 'thumbnail'
  creditsUsed  Int      @default(1)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([userId, createdAt])
  @@map("usage_logs")
}

// ============================================
// KEYWORD RESEARCH MODELS (Phase 1)
// ============================================

model KeywordResearch {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  keyword           String
  searchVolume      Int      // Monthly searches (estimated)
  competition       Int      // 1-100 score
  difficulty        String   // 'easy' | 'medium' | 'hard'
  trendDirection    String   // 'rising' | 'stable' | 'falling'

  // Analytics
  avgViews          Int?     // Average views for top videos
  avgLikes          Int?
  avgComments       Int?
  estimatedCPM      Float?   // Estimated revenue per 1000 views

  // Metadata
  relatedKeywords   Json?    // Array of related keywords
  topVideos         Json?    // Top 10 video data
  searchIntent      String?  // 'informational' | 'transactional' | 'navigational'
  lastUpdated       DateTime @default(now())

  // User actions
  isSaved           Boolean  @default(false)
  tags              String[] @default([])
  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([keyword])
  @@index([searchVolume])
  @@index([difficulty])
  @@map("keyword_research")
}

model SavedKeyword {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  keyword     String
  listName    String?  // Organize into lists (e.g., "Gaming Keywords", "Tech Reviews")
  tags        String[] @default([])
  notes       String?
  
  // Cached metrics for quick display
  searchVolume Int?
  competition  Int?
  difficulty   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, keyword])
  @@index([userId])
  @@index([listName])
  @@map("saved_keywords")
}

// ============================================
// COMPETITOR TRACKING MODELS (Phase 2)
// ============================================

model Competitor {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Channel Info
  channelId       String
  channelTitle    String
  channelUrl      String
  thumbnailUrl    String?
  description     String?  @db.Text
  category        String?  // User-defined category

  // Current Stats (snapshot)
  subscriberCount Int      @default(0)
  videoCount      Int      @default(0)
  viewCount       BigInt   @default(0)

  // Tracking
  isActive        Boolean  @default(true)
  lastChecked     DateTime @default(now())
  syncStatus      String   @default("idle") // idle | queued | syncing | success | failed
  lastSyncAt      DateTime?
  lastSyncQueuedAt DateTime?
  lastSyncReason  String?
  lastSyncError   String?  @db.Text
  syncFailureCount Int     @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  snapshots       CompetitorSnapshot[]
  videos          CompetitorVideo[]

  @@unique([userId, channelId])
  @@index([userId])
  @@index([channelId])
  @@map("competitors")
}

model CompetitorSnapshot {
  id              String      @id @default(cuid())
  competitorId    String
  competitor      Competitor  @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  subscriberCount Int
  videoCount      Int
  viewCount       BigInt

  // Growth calculations
  subsGrowth      Int         @default(0)
  viewsGrowth     BigInt      @default(0)

  createdAt       DateTime    @default(now())

  @@index([competitorId])
  @@index([createdAt])
  @@index([competitorId, createdAt])
  @@map("competitor_snapshots")
}

model CompetitorVideo {
  id              String      @id @default(cuid())
  competitorId    String
  competitor      Competitor  @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  videoId         String
  title           String
  description     String?     @db.Text
  thumbnailUrl    String?

  publishedAt     DateTime
  duration        Int?        // Seconds

  // Stats
  views           Int         @default(0)
  likes           Int?        @default(0)
  comments        Int?        @default(0)

  // Analysis
  keywords        String[]    @default([])
  isViral         Boolean     @default(false) // >2x avg views

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([competitorId, videoId])
  @@index([competitorId])
  @@index([publishedAt])
  @@index([competitorId, publishedAt])
  @@map("competitor_videos")
}

model CompetitorAlert {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String      // 'new_video' | 'viral' | 'keyword_overlap' | 'milestone'
  competitorId    String
  videoId         String?

  message         String
  isRead          Boolean     @default(false)

  createdAt       DateTime    @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("competitor_alerts")
}

