  utmTerm            String?
  offerCode          String?
  offerPercent       Int?
  offerMonths        Int?
  offerEligibleUntil DateTime?
  status             String    @default("new")
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([email, campaignId])
  @@index([campaignId, createdAt])
  @@index([status])
}
