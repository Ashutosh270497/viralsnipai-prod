# Database connection for Prisma / NextAuth
DATABASE_URL="mysql://root:password@localhost:3306/clippers"

# NextAuth configuration
NEXTAUTH_SECRET="dev-secret"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI API key (set to enable live LLM + Whisper)
OPENAI_API_KEY=""
# Default OpenAI model (used by most features)
OPENAI_MODEL="gpt-4o-mini"
# Agent Editor specific model (used by video editing agents)
AGENT_EDITOR_MODEL="gpt-4o-mini"

# Storage driver: "local" for disk, "s3" for object storage
STORAGE_DRIVER="local" # or "s3"
LOCAL_UPLOAD_DIR="./uploads"
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="us-east-1"
S3_PUBLIC_URL=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# FFmpeg binary override (leave empty to auto-detect from ffmpeg-static)
FFMPEG_PATH=""

# Transcription mode: true uses mocked transcripts, false hits Whisper
USE_MOCK_TRANSCRIBE="true" # dev default

# Optional SMTP credentials for email magic links
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
