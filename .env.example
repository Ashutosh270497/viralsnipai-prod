# ============================================
# OPENROUTER — Multi-LLM Gateway (March 2026)
# ============================================
# Get your key at: https://openrouter.ai/keys
# OpenRouter routes requests to 400+ models via a single OpenAI-compatible API.
# Set OPENROUTER_ENABLED=true to route all AI generation through OpenRouter
# (falls back to OpenAI automatically if OpenRouter fails).
#
# Pricing reference (per 1M tokens, input/output):
#   claude-sonnet-4.6      ~$3 / $15   — frontier creative + coding quality
#   gemini-2.5-flash       ~$0.15/$0.60 — 1M context, best JSON/structured output
#   gemini-2.5-flash-lite  ~$0.05/$0.30 — ultra-fast, cheapest tier
#
OPENROUTER_API_KEY="REPLACE_IN_ENV_LOCAL"
OPENROUTER_ENABLED="true"

# --- Per-feature model overrides (leave blank to use the defaults below) ---
# Hooks (creative 8-14 word headlines) — default: anthropic/claude-sonnet-4.6
OPENROUTER_HOOKS_MODEL="anthropic/claude-sonnet-4.6"
# Script writing (long-form prose) — default: anthropic/claude-sonnet-4.6
OPENROUTER_SCRIPTS_MODEL="anthropic/claude-sonnet-4.6"
# Highlight detection from transcripts — default: google/gemini-2.5-flash (1M ctx)
OPENROUTER_HIGHLIGHTS_MODEL="google/gemini-2.5-flash"
# Imagen prompt generation — default: google/gemini-2.5-flash
OPENROUTER_IMAGEN_PROMPT_MODEL="google/gemini-2.5-flash"
# Caption refinement — default: google/gemini-2.5-flash-lite
OPENROUTER_CAPTIONS_MODEL="google/gemini-2.5-flash-lite"
# Content calendar planning — default: anthropic/claude-sonnet-4.6
OPENROUTER_CONTENT_CALENDAR_MODEL="anthropic/claude-sonnet-4.6"
# Title generation — default: google/gemini-2.5-flash-lite
OPENROUTER_TITLES_MODEL="google/gemini-2.5-flash-lite"
# X/Thread generation — default: anthropic/claude-sonnet-4.6
OPENROUTER_THREADS_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar extension source analysis — default: google/gemini-2.5-flash
OPENROUTER_SNIPRADAR_EXTENSION_ANALYSIS_MODEL="google/gemini-2.5-flash"
# SnipRadar extension reply assist — default: google/gemini-2.5-flash
OPENROUTER_SNIPRADAR_EXTENSION_REPLY_MODEL="google/gemini-2.5-flash"
# SnipRadar extension remix assist — default: google/gemini-2.5-flash
OPENROUTER_SNIPRADAR_EXTENSION_REMIX_MODEL="google/gemini-2.5-flash"
# SnipRadar viral analysis / viral feed analysis — default: google/gemini-2.5-flash
OPENROUTER_SNIPRADAR_VIRAL_ANALYSIS_MODEL="google/gemini-2.5-flash"
# SnipRadar draft generation / Live Draft Studio — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_DRAFT_GENERATION_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar predictor scoring — default: openai/gpt-4.1-mini
OPENROUTER_SNIPRADAR_PREDICTION_MODEL="openai/gpt-4.1-mini"
# SnipRadar Variant Lab generation — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_VARIANT_GENERATION_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar Variant Lab scoring — default: openai/gpt-4.1-mini
OPENROUTER_SNIPRADAR_VARIANT_SCORING_MODEL="openai/gpt-4.1-mini"
# SnipRadar Research Copilot briefs — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_RESEARCH_BRIEF_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar Research Copilot embeddings — default: openai/text-embedding-3-small
OPENROUTER_SNIPRADAR_RESEARCH_EMBEDDING_MODEL="openai/text-embedding-3-small"
# SnipRadar engagement reply suggestions — default: openai/gpt-4.1-mini
OPENROUTER_SNIPRADAR_ENGAGEMENT_REPLIES_MODEL="openai/gpt-4.1-mini"
# SnipRadar template remix — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_TEMPLATES_REMIX_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar style analysis — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_STYLE_ANALYSIS_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar style rewrite — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_STYLE_REWRITE_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar hook generation — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_HOOKS_MODEL="anthropic/claude-sonnet-4.6"
# SnipRadar thread generation — default: anthropic/claude-sonnet-4.6
OPENROUTER_SNIPRADAR_THREADS_MODEL="anthropic/claude-sonnet-4.6"
WHISPER_MODEL="whisper-1"
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="./uploads"
