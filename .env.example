# =================================================================
# ViralSnipAI — Environment Variables Reference
# =================================================================
# Copy this file to apps/web/.env.local for local development.
# Keep apps/web/.env minimal with DATABASE_URL only so Prisma CLI
# commands continue to work independently of the runtime app.
#
# SECURITY: Never commit real secrets. Rotate any value that was
# previously committed. Production secrets must live only in your
# deployment platform (Vercel / Coolify / VPS env injection).
#
# Sections:
#   [V1 REQUIRED]  — Needed for the V1 core video-repurposing launch
#   [V2 OPTIONAL]  — Creator growth module (disabled by default)
#   [V3 OPTIONAL]  — Automation OS / SnipRadar (disabled by default)
#   [DISABLED/BETA] — Not yet launched; keep commented or false
# =================================================================


# =================================================================
# [V1 REQUIRED] DATABASE — Supabase / PostgreSQL
# =================================================================
# Direct connection (required for NextAuth + Prisma migrations).
# Get from: Supabase Dashboard → Settings → Database → Connection
# String → Prisma tab (NOT the pooler URL).
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Local development alternative (with docker compose up -d):
# DATABASE_URL="postgresql://clippers:clippers_local@localhost:5432/clippers"

# Pooled connection — for serverless environments (pgbouncer).
# NOT compatible with NextAuth database sessions; use only for
# read-heavy background jobs if needed.
# DATABASE_POOL_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"


# =================================================================
# [V1 REQUIRED] SUPABASE API KEYS
# =================================================================
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Use publishable key (new projects, starts with sb_publishable_):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<your-publishable-key>"

# OR legacy anon key (still supported, JWT format):
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"

# Server-side secret key (never expose to the browser):
# New format starts with sb_secret_ | legacy format is service_role JWT
SUPABASE_SECRET_KEY="<your-supabase-secret-key>"


# =================================================================
# [V1 REQUIRED] NEXTAUTH
# =================================================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="<generate-with-openssl-rand-base64-32>"
NEXTAUTH_URL="http://localhost:3000"


# =================================================================
# [V1 REQUIRED] GOOGLE OAUTH
# =================================================================
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="<your-google-client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"


# =================================================================
# [V1 REQUIRED] AI — OPENROUTER (primary) + OPENAI (fallback/media)
# =================================================================
# OpenRouter is the primary text-model gateway for most AI flows.
# OpenAI is still required for: Whisper transcription, TTS, DALL-E.

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY="<your-openrouter-api-key>"
OPENROUTER_ENABLED="true"

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY="<your-openai-api-key>"
OPENAI_MODEL="gpt-4o-mini"
TTS_MODEL="tts-1"
WHISPER_MODEL="whisper-1"

# --- Per-feature model overrides (leave blank to use coded defaults) ---
# Verified against OpenRouter model IDs on 2026-04-25.
# Video/audio ingest metadata and future direct multimodal ingest.
OPENROUTER_VIDEO_INGEST_MODEL="google/gemini-3-flash-preview"
# Hooks (creative 8-14 word headlines).
OPENROUTER_HOOKS_MODEL="anthropic/claude-sonnet-4.6"
# Script writing (long-form prose).
OPENROUTER_SCRIPTS_MODEL="anthropic/claude-sonnet-4.6"
# Auto-highlight detection from long transcripts/video context.
OPENROUTER_HIGHLIGHTS_MODEL="google/gemini-3.1-pro-preview"
# Caption refinement, cleanup, and platform transforms.
OPENROUTER_CAPTIONS_MODEL="google/gemini-3.1-flash-lite-preview"
# Content calendar planning.
OPENROUTER_CONTENT_CALENDAR_MODEL="anthropic/claude-sonnet-4.6"
# Title generation and short copy.
OPENROUTER_TITLES_MODEL="google/gemini-3.1-flash-lite-preview"
# Imagen prompt rewrite.
OPENROUTER_IMAGEN_PROMPT_MODEL="google/gemini-3.1-flash-lite-preview"


# =================================================================
# [V1 REQUIRED] STORAGE
# =================================================================
# "local" stores uploads in ./uploads (dev only).
# "s3" uses any S3-compatible bucket (production).
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="./uploads"

# S3-compatible storage (required when STORAGE_DRIVER=s3):
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="us-east-1"
S3_PUBLIC_URL=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""


# =================================================================
# [V1 REQUIRED] BILLING — RAZORPAY
# =================================================================
# Create at: https://dashboard.razorpay.com/app/keys
# Webhook secret: Razorpay Dashboard → Webhooks → Secret
RAZORPAY_KEY_ID="<your-razorpay-key-id>"
RAZORPAY_KEY_SECRET="<your-razorpay-key-secret>"
RAZORPAY_WEBHOOK_SECRET="<your-razorpay-webhook-secret>"
# Public key exposed to the browser for Razorpay Checkout:
NEXT_PUBLIC_RAZORPAY_KEY_ID="<your-razorpay-key-id>"
# Subscription plan IDs (starter / creator / studio, INR + USD):
RAZORPAY_PLAN_ID_STARTER_INR=""
RAZORPAY_PLAN_ID_CREATOR_INR=""
RAZORPAY_PLAN_ID_STUDIO_INR=""
RAZORPAY_PLAN_ID_STARTER_USD=""
RAZORPAY_PLAN_ID_CREATOR_USD=""
RAZORPAY_PLAN_ID_STUDIO_USD=""
# Optional promo offer IDs:
RAZORPAY_OFFER_ID_EARLY50=""
RAZORPAY_OFFER_ID_LAUNCH30=""


# =================================================================
# [V1 REQUIRED] APP URL
# =================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# =================================================================
# [V1 REQUIRED] FFMPEG
# =================================================================
# Ships with ffmpeg-static binaries. Override with a native binary
# if you hit codec errors (brew install ffmpeg, then set the path).
FFMPEG_PATH=""
USE_MOCK_TRANSCRIBE="false"
MAX_UPLOAD_MB="500"
MAX_VIDEO_DURATION_SECONDS="3600"
V1_FREE_MONTHLY_UPLOAD_LIMIT="3"
V1_FREE_MONTHLY_EXPORT_LIMIT="5"
V1_STARTER_MONTHLY_UPLOAD_LIMIT="25"
V1_STARTER_MONTHLY_EXPORT_LIMIT="50"
V1_CREATOR_MONTHLY_UPLOAD_LIMIT="100"
V1_CREATOR_MONTHLY_EXPORT_LIMIT="250"
V1_STUDIO_MONTHLY_UPLOAD_LIMIT="500"
V1_STUDIO_MONTHLY_EXPORT_LIMIT="1000"


# =================================================================
# [V1 REQUIRED] LOGGING
# =================================================================
LOG_LEVEL="info"


# =================================================================
# [V1 OPTIONAL] EMAIL / SMTP
# =================================================================
# Used for magic-link email login. Leave blank to disable email auth
# (Google OAuth will still work).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""


# =================================================================
# [V1 OPTIONAL] DEMO LOGIN (development only)
# =================================================================
# Shows a "Try the demo workspace" button on /signin. The demo NextAuth
# provider itself is only registered when NODE_ENV=development, so this
# flag has no effect in production even if set to true.
NEXT_PUBLIC_ENABLE_DEMO_LOGIN="false"


# =================================================================
# [V1 REQUIRED] LAUNCH VERSION FLAGS
# =================================================================
# V1 is enabled by default when this env is absent or true.
# Keep V2 and V3 false for the V1 launch.
NEXT_PUBLIC_V1_CORE_ENABLED="true"
NEXT_PUBLIC_V2_CREATOR_GROWTH_ENABLED="false"
NEXT_PUBLIC_V3_AUTOMATION_OS_ENABLED="false"


# =================================================================
# [V1 REQUIRED] FEATURE FLAGS — PLATFORM SHELL
# =================================================================
UI_V2_ENABLED="true"
NEXT_PUBLIC_UI_V2_ENABLED="true"


# =================================================================
# [V2 OPTIONAL] CREATOR GROWTH — INDIVIDUAL FEATURE OVERRIDES
# =================================================================
# Only needed if you want to test a V2 surface without enabling the
# full V2 group flag. Leave blank to inherit from the group flag.
NEXT_PUBLIC_FEATURE_VIRAL_HOOK_GENERATOR_ENABLED=""
NEXT_PUBLIC_FEATURE_PLATFORM_CAPTION_GENERATOR_ENABLED=""
NEXT_PUBLIC_FEATURE_CLIP_RANKING_DASHBOARD_ENABLED=""
NEXT_PUBLIC_FEATURE_CONTENT_CALENDAR_ENABLED=""
NEXT_PUBLIC_FEATURE_YOUTUBE_TITLE_GENERATOR_ENABLED=""
NEXT_PUBLIC_FEATURE_THUMBNAIL_IDEAS_ENABLED=""
NEXT_PUBLIC_FEATURE_BASIC_CREATOR_ANALYTICS_ENABLED=""
NEXT_PUBLIC_FEATURE_KEYWORD_RESEARCH_ENABLED=""


# =================================================================
# [V2 OPTIONAL] KEYWORD RESEARCH
# =================================================================
# YouTube Data API v3 — https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY="<your-youtube-data-api-key>"
ALLOW_YOUTUBE_MOCK_DATA="false"

# DataForSEO — optional enrichment for search volume + trends
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# Keyword discovery guardrails (sensible defaults shown):
KEYWORD_CACHE_TTL_HOURS="24"
KEYWORD_SEARCH_MAX_TOKENS="15"
KEYWORD_SEARCH_RATE_LIMIT_PER_MINUTE="12"
KEYWORD_SEARCH_RATE_LIMIT_PER_DAY="250"
KEYWORD_DISCOVERY_MAX_EXPANSIONS="8"
KEYWORD_DISCOVERY_RESULTS_PER_QUERY="12"
KEYWORD_DISCOVERY_MAX_TOTAL_VIDEOS="120"
KEYWORD_DISCOVERY_TIMEOUT_MS="9000"
KEYWORD_DISCOVERY_CONCURRENCY="4"
KEYWORD_SEARCH_QUEUE_CONCURRENCY="3"
KEYWORD_SEARCH_QUEUE_MAX_SIZE="60"
KEYWORD_SEARCH_TASK_TIMEOUT_MS="25000"
KEYWORD_METRICS_MAX_SAMPLES="1000"
KEYWORD_METRICS_WINDOW_SECONDS="3600"
KEYWORD_SEARCH_SLO_P95_MS="2500"
KEYWORD_SEARCH_SLO_ERROR_RATE_PCT="2"
KEYWORD_MAINTENANCE_CRON_SECRET="<generate-with-openssl-rand-hex-32>"
KEYWORD_HOT_REFRESH_STALE_HOURS="18"
KEYWORD_HOT_REFRESH_MAX_RECORDS="12"
KEYWORD_HOT_REFRESH_WORKERS="2"
KEYWORD_DEFAULT_COUNTRY="IN"
KEYWORD_DEFAULT_LANGUAGE="en"
KEYWORD_LIMIT_FREE_SEARCHES="40"
KEYWORD_LIMIT_FREE_RECOMMENDATIONS="12"
KEYWORD_LIMIT_FREE_SAVED="75"
KEYWORD_LIMIT_STARTER_SEARCHES="600"
KEYWORD_LIMIT_STARTER_RECOMMENDATIONS="160"
KEYWORD_LIMIT_STARTER_SAVED="1500"
KEYWORD_LIMIT_CREATOR_SEARCHES="-1"
KEYWORD_LIMIT_CREATOR_RECOMMENDATIONS="-1"
KEYWORD_LIMIT_CREATOR_SAVED="-1"
KEYWORD_LIMIT_STUDIO_SEARCHES="-1"
KEYWORD_LIMIT_STUDIO_RECOMMENDATIONS="-1"
KEYWORD_LIMIT_STUDIO_SAVED="-1"


# =================================================================
# [V2 OPTIONAL] THUMBNAIL GENERATOR — DALL-E / IMAGEN
# =================================================================
# OpenAI DALL-E (used when Imagen is disabled):
DALLE_MODEL="dall-e-3"

# Per-tier credit limits for generation features:
FREE_TIER_CREDITS=5
STARTER_TIER_CREDITS=50
CREATOR_TIER_CREDITS=200
STUDIO_TIER_CREDITS=999999


# =================================================================
# [V3 OPTIONAL] AUTOMATION OS — INDIVIDUAL FEATURE OVERRIDES
# =================================================================
NEXT_PUBLIC_FEATURE_SNIPRADAR_ENABLED=""
NEXT_PUBLIC_FEATURE_X_AUTOMATION_ENABLED=""
NEXT_PUBLIC_FEATURE_AUTO_SCHEDULING_ENABLED=""
NEXT_PUBLIC_FEATURE_COMPETITOR_TRACKING_ENABLED=""
NEXT_PUBLIC_FEATURE_RELATIONSHIP_CRM_ENABLED=""
NEXT_PUBLIC_FEATURE_API_WEBHOOKS_ENABLED=""
NEXT_PUBLIC_FEATURE_ADVANCED_AUTOMATION_ENABLED=""
NEXT_PUBLIC_FEATURE_ADVANCED_ANALYTICS_ENABLED=""


# =================================================================
# [V3 OPTIONAL] X / TWITTER API — SNIPRADAR
# =================================================================
# Create at: https://developer.twitter.com/en/portal/dashboard
X_API_KEY="<your-x-api-key>"
X_API_SECRET="<your-x-api-secret>"
X_CONSUMER_KEY="<your-x-consumer-key>"
X_ACCESS_TOKEN="<your-x-access-token>"
X_CLIENT_ID="<your-x-oauth2-client-id>"
X_CLIENT_SECRET="<your-x-oauth2-client-secret>"
X_CALLBACK_URL="http://localhost:3000/api/snipradar/callback"
X_API_TIMEOUT_MS="10000"
X_API_MAX_RETRIES="2"


# =================================================================
# [V3 OPTIONAL] SNIPRADAR SCHEDULER + MAINTENANCE CRON SECRETS
# =================================================================
# Generate: openssl rand -hex 32
SNIPRADAR_SCHEDULER_CRON_SECRET="<generate-with-openssl-rand-hex-32>"
SNIPRADAR_SCHEDULER_USER_DISPATCH_LIMIT="200"
SNIPRADAR_SCHEDULER_PER_USER_LIMIT="25"
SNIPRADAR_SCHEDULER_CRON_CONCURRENCY="10"
SNIPRADAR_MAINTENANCE_CRON_SECRET="<generate-with-openssl-rand-hex-32>"
SNIPRADAR_MAINTENANCE_METRICS_LIMIT="200"
SNIPRADAR_MAINTENANCE_METRICS_CONCURRENCY="4"
# Optional telemetry + alert webhook sinks:
SNIPRADAR_TELEMETRY_WEBHOOK_URL=""
SNIPRADAR_TELEMETRY_SUCCESS_SAMPLE_RATE="0.05"
SNIPRADAR_TELEMETRY_WARN_SAMPLE_RATE="0.5"
SNIPRADAR_ALERT_WEBHOOK_URL=""


# =================================================================
# [V3 OPTIONAL] SNIPRADAR — AI MODEL OVERRIDES
# =================================================================
# All default to sensible models in openrouter-client.ts.
# Override only when A/B testing or cost-tuning.
OPENROUTER_SNIPRADAR_EXTENSION_ANALYSIS_MODEL="google/gemini-3-flash-preview"
OPENROUTER_SNIPRADAR_EXTENSION_REPLY_MODEL="google/gemini-3.1-flash-lite-preview"
OPENROUTER_SNIPRADAR_EXTENSION_REMIX_MODEL="google/gemini-3-flash-preview"
OPENROUTER_SNIPRADAR_VIRAL_ANALYSIS_MODEL="google/gemini-3-flash-preview"
OPENROUTER_SNIPRADAR_DRAFT_GENERATION_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_PREDICTION_MODEL="openai/gpt-5.3-chat"
OPENROUTER_SNIPRADAR_VARIANT_GENERATION_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_VARIANT_SCORING_MODEL="openai/gpt-5.3-chat"
OPENROUTER_SNIPRADAR_RESEARCH_BRIEF_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_RESEARCH_EMBEDDING_MODEL="openai/text-embedding-3-small"
OPENROUTER_SNIPRADAR_ENGAGEMENT_REPLIES_MODEL="google/gemini-3.1-flash-lite-preview"
OPENROUTER_SNIPRADAR_TEMPLATES_REMIX_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_STYLE_ANALYSIS_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_STYLE_REWRITE_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_HOOKS_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_THREADS_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_THREADS_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_ASSISTANT_MODEL="google/gemini-3-flash-preview"
OPENROUTER_SNIPRADAR_GROWTH_PLANNER_MODEL="openai/gpt-5.3-chat"
OPENROUTER_SNIPRADAR_WINNER_LOOP_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_SNIPRADAR_GROWTH_COACH_MODEL="openai/gpt-5.3-chat"
OPENROUTER_SNIPRADAR_INBOX_ENRICHMENT_MODEL="google/gemini-3.1-flash-lite-preview"
OPENROUTER_SNIPRADAR_PROFILE_AUDIT_MODEL="openai/gpt-5.3-chat"
OPENROUTER_PLAN_STARTER_MODEL="google/gemini-3.1-flash-lite-preview"
OPENROUTER_PLAN_CREATOR_MODEL="google/gemini-3-flash-preview"
OPENROUTER_PLAN_STUDIO_MODEL="anthropic/claude-sonnet-4.6"
INGEST_SECRET="<generate-with-openssl-rand-hex-32>"


# =================================================================
# [V3 OPTIONAL] SNIPRADAR — LEGACY COMPAT FLAGS
# =================================================================
# These are now resolved through NEXT_PUBLIC_V3_AUTOMATION_OS_ENABLED
# and NEXT_PUBLIC_FEATURE_SNIPRADAR_ENABLED. Listed here only for
# backward compatibility with older deployment configs — set all to
# false for V1 launch.
SNIPRADAR_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_ENABLED="false"
SNIPRADAR_V2_OVERVIEW_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_V2_OVERVIEW_ENABLED="false"
SNIPRADAR_V2_ANALYTICS_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_V2_ANALYTICS_ENABLED="false"
SNIPRADAR_V2_CREATE_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_V2_CREATE_ENABLED="false"
SNIPRADAR_V2_DISCOVER_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_V2_DISCOVER_ENABLED="false"
SNIPRADAR_V2_PUBLISH_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_V2_PUBLISH_ENABLED="false"
SNIPRADAR_V2_GROWTH_PLAN_ENABLED="false"
NEXT_PUBLIC_SNIPRADAR_V2_GROWTH_PLAN_ENABLED="false"
WINNER_LOOP_ENABLED="false"
RELATIONSHIPS_CRM_ENABLED="false"
API_WEBHOOKS_ENABLED="false"
AUTO_DM_ENABLED="false"
YOUTUBE_REPURPOSE_OS_ENABLED="true"
YOUTUBE_VOICER_ENABLED="false"
YOUTUBE_THUMBNAIL_GENERATOR_ENABLED="false"


# =================================================================
# [DISABLED / BETA] ADVANCED AI — IMAGEN, VEO, VOICE CLONING
# =================================================================
# These require NEXT_PUBLIC_V3_AUTOMATION_OS_ENABLED=true AND the
# individual feature flag. Disabled by default.

NEXT_PUBLIC_FEATURE_IMAGEN_ENABLED=""
NEXT_PUBLIC_FEATURE_VEO_ENABLED=""
NEXT_PUBLIC_FEATURE_VOICE_CLONING_ENABLED=""

# Google Gemini / Imagen / Veo:
GOOGLE_GEMINI_API_KEY="<your-google-gemini-api-key>"
GOOGLE_GEMINI_MODEL="gemini-2.5-flash"
GOOGLE_NANO_BANANA_API_KEY="<your-google-imagen-api-key>"
GOOGLE_IMAGEN_MODEL="gemini-2.5-flash-image"
# Veo — also requires FORCE_VEO_ENABLED=true as a secondary guard:
FORCE_VEO_ENABLED="false"
VEO_ENABLED="false"
NEXT_PUBLIC_VEO_ENABLED="false"
# GOOGLE_VEO_API_KEY="<your-google-veo-api-key>"
# GOOGLE_VEO_MODEL="veo-2.0-generate-001"
# GOOGLE_VEO_PROJECT_ID=""
# GOOGLE_VEO_LOCATION="us-central1"
# GOOGLE_VEO_OUTPUT_URI=""
# GOOGLE_VEO_SERVICE_ACCOUNT_KEY_PATH=""

# ElevenLabs — voice cloning:
ELEVENLABS_API_KEY=""
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"

# Sora — OpenAI video (placeholder, not live):
SORA_MODEL="sora-2"
SORA_ENABLED="false"
NEXT_PUBLIC_SORA_ENABLED="false"

# Transcribe workspace UI (hidden by default):
TRANSCRIBE_UI_ENABLED="false"
NEXT_PUBLIC_TRANSCRIBE_UI_ENABLED="false"
IMAGEN_ENABLED="false"
NEXT_PUBLIC_IMAGEN_ENABLED="false"
VOICER_ENABLED="false"
NEXT_PUBLIC_VOICER_ENABLED="false"


# =================================================================
# [V1 OPTIONAL] YOUTUBE INGEST
# =================================================================
# yt-dlp cookie auth — only needed for age-restricted/restricted videos.
# YT_DLP_COOKIES_PATH="/path/to/cookies.txt"
# YT_DLP_COOKIES_FROM_BROWSER="chrome"
