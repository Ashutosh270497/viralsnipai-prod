# ViralSnipAI staging environment template.
# Keep real values in the deployment provider or secrets manager, not in git.

NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://staging.viralsnipai.com"
NEXTAUTH_URL="https://staging.viralsnipai.com"
NEXTAUTH_SECRET="<staging-only-secret>"

DATABASE_URL="postgresql://<staging-user>:<password>@<staging-host>:5432/<db>"

OPENAI_API_KEY="<staging-openai-key>"
OPENROUTER_API_KEY="<staging-openrouter-key>"

STORAGE_DRIVER="s3"
S3_BUCKET="viralsnipai-staging"
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_PUBLIC_URL=""
S3_ACCESS_KEY_ID="<staging-s3-access-key>"
S3_SECRET_ACCESS_KEY="<staging-s3-secret>"

RAZORPAY_KEY_ID="<razorpay-test-key-id>"
RAZORPAY_KEY_SECRET="<razorpay-test-key-secret>"
RAZORPAY_WEBHOOK_SECRET="<razorpay-staging-webhook-secret>"
NEXT_PUBLIC_RAZORPAY_KEY_ID="<razorpay-test-key-id>"

UPSTASH_REDIS_REST_URL="<staging-upstash-url>"
UPSTASH_REDIS_REST_TOKEN="<staging-upstash-token>"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="ViralSnipAI Staging <no-reply@staging.viralsnipai.com>"
EMAIL_REPLY_TO="support@viralsnipai.com"

SENTRY_DSN=""
BETTERSTACK_API_KEY=""
UPTIME_MONITOR_URL="https://staging.viralsnipai.com/api/health"

MAX_UPLOAD_MB="500"
MAX_VIDEO_DURATION_SECONDS="3600"
WEB_CONCURRENCY="1"
HEALTH_DEEP_CHECK="false"

NEXT_PUBLIC_V1_CORE_ENABLED="true"
NEXT_PUBLIC_V2_CREATOR_GROWTH_ENABLED="false"
NEXT_PUBLIC_V3_AUTOMATION_OS_ENABLED="false"
NEXT_PUBLIC_FEATURE_SNIPRADAR_ENABLED="false"
NEXT_PUBLIC_FEATURE_IMAGEN_ENABLED="false"
NEXT_PUBLIC_FEATURE_VEO_ENABLED="false"
NEXT_PUBLIC_FEATURE_VOICE_CLONING_ENABLED="false"
NEXT_PUBLIC_ENABLE_SOCIAL_PUBLISHING="false"
NEXT_PUBLIC_ENABLE_EXPORT_TRANSLATION="false"
NEXT_PUBLIC_ENABLE_ADVANCED_EXPORT="false"
NEXT_PUBLIC_ENABLE_ADVANCED_REPURPOSE="false"
NEXT_PUBLIC_ENABLE_ADVANCED_EDITOR="false"
